{
  "name": "SpecNext Dark",
  "type": "dark",
  "colors": {
    "editor.background": "#000000",
    "editor.foreground": "#d7d7d7",
    "editorLineNumber.foreground": "#5f5f5f",
    "editorCursor.foreground": "#00e0e0",
    "editor.selectionBackground": "#003a3a",
    "editor.lineHighlightBackground": "#101010"
  },
  "tokenColors": [
    {
      "name": "BASIC line numbers",
      "scope": "constant.numeric.line-number.nextbasic",
      "settings": { "foreground": "#5f5f5f" }
    },
    {
      "name": "Statements (PRINT, LET, GO TO ...)",
      "scope": "keyword.control.statement.nextbasic",
      "settings": { "foreground": "#ffe100", "fontStyle": "bold" }
    },
    {
      "name": "Functions (RND, INT, CHR$ ...)",
      "scope": "support.function.nextbasic",
      "settings": { "foreground": "#00e0e0" }
    },
    {
      "name": "Word operators (AND, OR, TO ...)",
      "scope": "keyword.operator.word.nextbasic",
      "settings": { "foreground": "#ffe100" }
    },
    {
      "name": "Strings",
      "scope": "string.quoted.double.nextbasic",
      "settings": { "foreground": "#3fd94a" }
    },
    {
      "name": "Numbers",
      "scope": "constant.numeric.nextbasic",
      "settings": { "foreground": "#e86fd0" }
    },
    {
      "name": "REM keyword",
      "scope": "keyword.control.rem.nextbasic",
      "settings": { "foreground": "#7a7a7a", "fontStyle": "bold" }
    },
    {
      "name": "REM comment text",
      "scope": "comment.line.rem.nextbasic",
      "settings": { "foreground": "#7a7a7a", "fontStyle": "italic" }
    },
    {
      "name": "Block graphics and escapes",
      "scope": "constant.character.escape.nextbasic, constant.character.escape.block-graphics.nextbasic",
      "settings": { "foreground": "#ff5c5c" }
    },
    {
      "name": "Operators",
      "scope": "keyword.operator.nextbasic",
      "settings": { "foreground": "#ffffff" }
    },
    {
      "name": "Variables",
      "scope": "variable.other.nextbasic",
      "settings": { "foreground": "#d7d7d7" }
    }
  ]
}
