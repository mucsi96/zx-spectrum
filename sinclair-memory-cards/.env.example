# Copy this file to ".env" and fill in your keys.
# The generator loads .env automatically; real environment variables still win.
# NEVER commit the real .env — it is git-ignored.

OPENAI_API_KEY=sk-...        # GPT 5.5, used to write each image prompt
IDEOGRAM_API_KEY=...         # Ideogram 4 Turbo, used to draw the pictures

# Optional overrides:
# OPENAI_TEXT_MODEL=gpt-5.5
# IDEOGRAM_URL=https://api.ideogram.ai/v1/ideogram-v4/generate
# IDEOGRAM_RENDERING_SPEED=TURBO
# IDEOGRAM_ASPECT_RATIO=1x1     # unset = model chooses; set e.g. 1x1 for square pictures
