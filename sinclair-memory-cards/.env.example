# Copy this file to ".env" and fill in your keys.
# The generator loads .env automatically; real environment variables still win.
# NEVER commit the real .env — it is git-ignored.

OPENAI_API_KEY=sk-...        # GPT 5.6 writes the prompts; also draws with --image-backend openai
IDEOGRAM_API_KEY=...         # Ideogram 4 Turbo (the default image backend)

# Optional overrides:
# IMAGE_BACKEND=ideogram        # default for --image-backend: ideogram | openai
# OPENAI_TEXT_MODEL=gpt-5.6-sol
# OPENAI_IMAGE_MODEL=gpt-image-2
# IDEOGRAM_URL=https://api.ideogram.ai/v1/ideogram-v4/generate
# IDEOGRAM_RENDERING_SPEED=TURBO
# IDEOGRAM_ASPECT_RATIO=1x1     # default 1x1 (square); set empty to let the model choose
