+
+
+/*
+
+NextBASIC host-disk handler (TBBlue / ZX Spectrum Next)
+
+Makes NextBASIC SAVE/LOAD/MERGE with a plain filename (no drive letter, no
+path, no extension) operate on raw tokenized BASIC files <dir>/<name>.bas in
+a host directory, instead of the emulated SD card:
+
+    SAVE "lib"   -> writes <dir>/lib.bas
+    LOAD "game"  -> reads  <dir>/game.bas
+    MERGE "lib"  -> merges <dir>/lib.bas
+    SAVE ""      -> re-saves to the last file opened through this handler
+    ERASE "lib"  -> deletes <dir>/lib.bas
+
+Host files are raw tokenized BASIC without the 128-byte PLUS3DOS header;
+the header is synthesized on LOAD and stripped on SAVE. Saves are written
+atomically (temp file + rename).
+
+It works by trapping the +3DOS API jump table entries (DOS_OPEN 0106h,
+DOS_CLOSE 0109h, DOS_READ 0112h, ...) when the machine is TBBlue in +3e
+mode with the DOS ROM (ROM 2) paged in - the way NextZXOS/NextBASIC
+performs all its file access. Filespecs containing ':', '/', '\', '.' or
+wildcards are left alone and fall through to the real NextZXOS, so the OS
+still boots and runs from its SD image.
+
+Inert unless the environment variable ZESARUX_NEXTBASIC_DIR is set.
+
+*/
+
+//Auto-disables itself on the first call if ZESARUX_NEXTBASIC_DIR is unset
+z80_bit nextbasic_hostdisk_traps={1};
+
+#define NBHD_MAX_FILES 16
+#define NBHD_MAX_NAME 64
+#define NBHD_MAX_PATH 4096
+
+//+3DOS header data (type,length,param1,param2) for file number B is kept in
+//RAM page 7, which NextZXOS maps at C000h-FFFFh while servicing DOS calls.
+//DOS_REF_HEAD returns IX pointing here and the BASIC ROM reads/writes the
+//8 bytes directly
+#define NBHD_HEADER_BASE 0xFF00
+
+struct s_nbhd_file {
+    int inuse;
+    int dirty;
+    z80_byte *buf;
+    int allocated;
+    int size;
+    int pos;
+    char name[NBHD_MAX_NAME];
+};
+
+static struct s_nbhd_file nbhd_files[NBHD_MAX_FILES];
+static char *nbhd_dir=NULL;
+static char nbhd_last_name[NBHD_MAX_NAME]="";
+
+//ZESARUX_NEXTBASIC_AUTOLOAD: boot straight into a program instead of the
+//NextZXOS menu. The handler serves a synthetic c:/nextzxos/autoexec.bas
+//("10 LOAD "<name>"") and gives the loaded program an autostart line, so
+//it LOADs and RUNs with no interaction. When the program ends, NextZXOS
+//shows its menu as usual. Value "-" serves an empty autoexec ("10 REM"),
+//which suppresses any real autoexec on the SD image and boots to the menu
+static char *nbhd_autoload=NULL;
+static int nbhd_autoload_pending=0;
+
+static void nbhd_return_ok(void)
+{
+    Z80_FLAGS |=FLAG_C;
+    reg_pc=pop_valor();
+}
+
+static void nbhd_return_error(z80_byte error_code)
+{
+    reg_a=error_code;
+    Z80_FLAGS=(Z80_FLAGS & (255-FLAG_C));
+    reg_pc=pop_valor();
+}
+
+//Memory access honouring the +3DOS convention: addresses C000h-FFFFh refer
+//to 16K RAM page "page" (which the real DOS would map there), addresses
+//below use the current paging (RAM 5 / RAM 2 in the DOS configuration).
+//A transfer running past FFFFh wraps to C000h of the next page
+static z80_byte nbhd_peek(z80_byte page,z80_int dir)
+{
+    if (dir>=49152) return tbblue_ram_memory_pages[((page&7)<<1)|((dir>>13)&1)][dir&8191];
+    return tbblue_memory_paged[dir>>13][dir&8191];
+}
+
+static void nbhd_poke(z80_byte page,z80_int dir,z80_byte value)
+{
+    if (dir>=49152) {
+        tbblue_ram_memory_pages[((page&7)<<1)|((dir>>13)&1)][dir&8191]=value;
+        return;
+    }
+    if (dir<16384) return; //never write to the ROM area
+    tbblue_memory_paged[dir>>13][dir&8191]=value;
+}
+
+static void nbhd_advance(z80_byte *page,z80_int *dir)
+{
+    if (*dir==65535) {
+        *dir=49152;
+        (*page)++;
+    }
+    else (*dir)++;
+}
+
+static z80_byte nbhd_peek_page7(z80_int dir)
+{
+    return tbblue_ram_memory_pages[14|((dir>>13)&1)][dir&8191];
+}
+
+static void nbhd_poke_page7(z80_int dir,z80_byte value)
+{
+    tbblue_ram_memory_pages[14|((dir>>13)&1)][dir&8191]=value;
+}
+
+static void nbhd_set_header(z80_byte fnum,z80_byte type,int length,int param1,int param2)
+{
+    z80_int base=NBHD_HEADER_BASE+8*fnum;
+    nbhd_poke_page7(base,type);
+    nbhd_poke_page7(base+1,length&0xFF);
+    nbhd_poke_page7(base+2,(length>>8)&0xFF);
+    nbhd_poke_page7(base+3,param1&0xFF);
+    nbhd_poke_page7(base+4,(param1>>8)&0xFF);
+    nbhd_poke_page7(base+5,param2&0xFF);
+    nbhd_poke_page7(base+6,(param2>>8)&0xFF);
+    nbhd_poke_page7(base+7,0);
+}
+
+//Only plain names are handled by this handler. Anything with a path, drive,
+//extension or wildcard falls through to the real NextZXOS
+static int nbhd_valid_name(const char *name)
+{
+    int i;
+    if (name[0]==0) return 0;
+    for (i=0;name[i];i++) {
+        char c=name[i];
+        if (! ( (c>='A' && c<='Z') || (c>='a' && c<='z') || (c>='0' && c<='9')
+             || c=='_' || c=='-' || c==' ' ) ) return 0;
+    }
+    return 1;
+}
+
+static int nbhd_strcaseeq(const char *a,const char *b)
+{
+    while (*a && *b) {
+        char ca=*a, cb=*b;
+        if (ca>='A' && ca<='Z') ca +=32;
+        if (cb>='A' && cb<='Z') cb +=32;
+        if (ca!=cb) return 0;
+        a++;
+        b++;
+    }
+    return (*a==0 && *b==0);
+}
+
+//Build host path for name. Returns non-zero if the file exists; falls back
+//to a case-insensitive directory search (Spectrum users mix cases freely)
+static int nbhd_find_host_file(const char *name,char *path)
+{
+    struct stat st;
+
+    snprintf(path,NBHD_MAX_PATH,"%s/%s.bas",nbhd_dir,name);
+    if (stat(path,&st)==0) return 1;
+
+    DIR *d=opendir(nbhd_dir);
+    if (d!=NULL) {
+        struct dirent *entry;
+        while ((entry=readdir(d))!=NULL) {
+            char base[NBHD_MAX_NAME+8];
+            int l=strlen(entry->d_name);
+            if (l<5 || l>=(int)sizeof(base)) continue;
+            strcpy(base,entry->d_name);
+            if (!nbhd_strcaseeq(&base[l-4],".bas")) continue;
+            base[l-4]=0;
+            if (nbhd_strcaseeq(base,name)) {
+                snprintf(path,NBHD_MAX_PATH,"%s/%s",nbhd_dir,entry->d_name);
+                closedir(d);
+                return 1;
+            }
+        }
+        closedir(d);
+    }
+
+    return 0;
+}
+
+static int nbhd_ensure_capacity(struct s_nbhd_file *f,int needed)
+{
+    if (needed<=f->allocated) return 1;
+    int newalloc=needed+16384;
+    z80_byte *newbuf=realloc(f->buf,newalloc);
+    if (newbuf==NULL) return 0;
+    memset(&newbuf[f->allocated],0,newalloc-f->allocated);
+    f->buf=newbuf;
+    f->allocated=newalloc;
+    return 1;
+}
+
+static void nbhd_free_file(struct s_nbhd_file *f)
+{
+    if (f->buf!=NULL) free(f->buf);
+    memset(f,0,sizeof(*f));
+}
+
+//Reads a 0FFh-terminated +3DOS filespec from emulated memory
+static void nbhd_read_filespec(z80_int dir,char *name)
+{
+    int i;
+    for (i=0;i<NBHD_MAX_NAME-1;i++) {
+        z80_byte c=peek_byte_no_time(dir+i);
+        if (c==0xFF || c==0 || c==0x0D) break;
+        name[i]=c;
+    }
+    name[i]=0;
+    while (i>0 && name[i-1]==' ') name[--i]=0;
+}
+
+//Serves a synthetic autoexec.bas: "10 LOAD "<name>"" (or "10 REM" for "-")
+static void nbhd_serve_autoexec(z80_byte fnum)
+{
+    struct s_nbhd_file *f=&nbhd_files[fnum];
+    nbhd_free_file(f);
+
+    z80_byte body[NBHD_MAX_NAME+16];
+    int len=0;
+
+    body[len++]=0x00; body[len++]=0x0A; //line 10, big endian
+    len +=2; //line length filled below
+    if (!strcmp(nbhd_autoload,"-")) {
+        body[len++]=0xEA; //REM
+    }
+    else {
+        body[len++]=0xEF; //LOAD
+        body[len++]='"';
+        int i;
+        for (i=0;nbhd_autoload[i] && i<NBHD_MAX_NAME-1;i++) body[len++]=nbhd_autoload[i];
+        body[len++]='"';
+        nbhd_autoload_pending=1; //give the next plain-name LOAD an autostart line
+    }
+    body[len++]=0x0D;
+    body[2]=(len-4)&0xFF; body[3]=((len-4)>>8)&0xFF;
+
+    if (!nbhd_ensure_capacity(f,len)) return;
+    memcpy(f->buf,body,len);
+    f->inuse=1;
+    f->size=len;
+    strcpy(f->name,"");
+    nbhd_set_header(fnum,0,len,10,len); //autostart at line 10
+    debug_printf(VERBOSE_INFO,"NextBASIC host disk: serving synthetic autoexec (autoload '%s')",nbhd_autoload);
+    Z80_FLAGS=(Z80_FLAGS & (255-FLAG_Z));
+    nbhd_return_ok();
+}
+
+static void nbhd_dos_open(void)
+{
+    char name[NBHD_MAX_NAME];
+    char path[NBHD_MAX_PATH];
+    z80_byte fnum=reg_b;
+
+    if (fnum>=NBHD_MAX_FILES) return;
+
+    nbhd_read_filespec(reg_hl,name);
+
+    debug_printf(VERBOSE_INFO,"NextBASIC host disk: DOS_OPEN B=%d C=%d D=%d E=%d name='%s'",reg_b,reg_c,reg_d,reg_e,name);
+
+    if (nbhd_autoload!=NULL) {
+        int l=strlen(name);
+        if (l>=12 && nbhd_strcaseeq(&name[l-12],"autoexec.bas")) {
+            nbhd_serve_autoexec(fnum);
+            return;
+        }
+    }
+
+    //access modes 2 (exclusive-write) and 3 (exclusive-read-write) mean SAVE
+    int write_mode=((reg_c&7)==2 || (reg_c&7)==3);
+
+    //SAVE "@" / LOAD "@" -> the last file opened through this handler.
+    //(The NextBASIC ROM rejects SAVE "" with "Invalid file name" before it
+    //ever reaches +3DOS, so an empty name can not be used for this)
+    if (!strcmp(name,"@") && nbhd_last_name[0]) strcpy(name,nbhd_last_name);
+
+    if (!nbhd_valid_name(name)) return;
+
+    struct s_nbhd_file *f=&nbhd_files[fnum];
+    nbhd_free_file(f);
+
+    if (write_mode) {
+        debug_printf(VERBOSE_INFO,"NextBASIC host disk: open for write: %s",name);
+        f->inuse=1;
+        strcpy(f->name,name);
+        strcpy(nbhd_last_name,name);
+        nbhd_set_header(fnum,0,0,0x8000,0);
+        Z80_FLAGS |=FLAG_Z; //newly created
+        nbhd_return_ok();
+        return;
+    }
+
+    //LOAD / MERGE
+    if (!nbhd_find_host_file(name,path)) {
+        debug_printf(VERBOSE_INFO,"NextBASIC host disk: not found: %s",name);
+        nbhd_return_error(23); //File not found
+        return;
+    }
+
+    FILE *host=fopen(path,"rb");
+    if (host==NULL) {
+        nbhd_return_error(23);
+        return;
+    }
+
+    fseek(host,0,SEEK_END);
+    int size=ftell(host);
+    fseek(host,0,SEEK_SET);
+    if (size<0) size=0;
+    if (size>0xFFFF) size=0xFFFF; //BASIC files can never be bigger anyway
+
+    if (!nbhd_ensure_capacity(f,size)) {
+        fclose(host);
+        nbhd_return_error(23);
+        return;
+    }
+
+    if (fread(f->buf,1,size,host)!=(size_t)size) {
+        fclose(host);
+        nbhd_free_file(f);
+        nbhd_return_error(23);
+        return;
+    }
+    fclose(host);
+
+    debug_printf(VERBOSE_INFO,"NextBASIC host disk: open for read: %s (%d bytes)",path,size);
+
+    f->inuse=1;
+    f->size=size;
+    strcpy(f->name,name);
+    strcpy(nbhd_last_name,name);
+
+    //synthesize +3DOS header: BASIC program, no autostart, no variables area.
+    //If this load was requested by the synthetic autoexec, set the autostart
+    //line to the program's first line so it RUNs by itself
+    int param1=0x8000;
+    if (nbhd_autoload_pending && size>=2) {
+        param1=(f->buf[0]<<8)|f->buf[1];
+        nbhd_autoload_pending=0;
+    }
+    nbhd_set_header(fnum,0,size,param1,size);
+
+    Z80_FLAGS=(Z80_FLAGS & (255-FLAG_Z)); //existing file opened
+    nbhd_return_ok();
+}
+
+static struct s_nbhd_file *nbhd_get_open_file(void)
+{
+    if (reg_b>=NBHD_MAX_FILES) return NULL;
+    if (!nbhd_files[reg_b].inuse) return NULL;
+    return &nbhd_files[reg_b];
+}
+
+static void nbhd_dos_close(void)
+{
+    struct s_nbhd_file *f=nbhd_get_open_file();
+    if (f==NULL) return;
+
+    if (f->dirty) {
+        z80_int base=NBHD_HEADER_BASE+8*reg_b;
+        z80_byte type=nbhd_peek_page7(base);
+        int param2=nbhd_peek_page7(base+5) | (nbhd_peek_page7(base+6)<<8);
+
+        //For a BASIC program (type 0) param2 is the length of the program
+        //without variables: truncate there so the host .bas file stays a
+        //clean tokenized listing
+        int save_size=f->size;
+        if (type==0 && param2>0 && param2<=f->size) save_size=param2;
+
+        char path[NBHD_MAX_PATH];
+        char tmppath[NBHD_MAX_PATH];
+        snprintf(path,NBHD_MAX_PATH,"%s/%s.bas",nbhd_dir,f->name);
+        snprintf(tmppath,NBHD_MAX_PATH,"%s/.%s.bas.tmp",nbhd_dir,f->name);
+
+        //overwrite an existing file even if it differs in case
+        nbhd_find_host_file(f->name,path);
+
+        FILE *host=fopen(tmppath,"wb");
+        if (host==NULL) {
+            nbhd_free_file(f);
+            nbhd_return_error(26); //Disk full
+            return;
+        }
+
+        int ok=((int)fwrite(f->buf,1,save_size,host)==save_size);
+        if (fclose(host)!=0) ok=0;
+        if (ok && rename(tmppath,path)!=0) ok=0;
+
+        debug_printf(VERBOSE_INFO,"NextBASIC host disk: %s %s (%d bytes)",
+            ok ? "saved" : "FAILED saving",path,save_size);
+
+        if (!ok) {
+            nbhd_free_file(f);
+            nbhd_return_error(26);
+            return;
+        }
+    }
+
+    nbhd_free_file(f);
+    nbhd_return_ok();
+}
+
+static void nbhd_dos_abandon(void)
+{
+    struct s_nbhd_file *f=nbhd_get_open_file();
+    if (f==NULL) return;
+
+    nbhd_free_file(f);
+    nbhd_return_ok();
+}
+
+static void nbhd_dos_ref_head(void)
+{
+    struct s_nbhd_file *f=nbhd_get_open_file();
+    if (f==NULL) return;
+
+    reg_ix=NBHD_HEADER_BASE+8*reg_b;
+    Z80_FLAGS=(Z80_FLAGS & (255-FLAG_Z)); //file has a header
+    nbhd_return_ok();
+}
+
+static void nbhd_dos_read(void)
+{
+    struct s_nbhd_file *f=nbhd_get_open_file();
+    if (f==NULL) return;
+
+    int count=(reg_de==0 ? 65536 : reg_de);
+    int available=f->size - f->pos;
+    int tocopy=(count<available ? count : available);
+
+    z80_byte page=reg_c;
+    z80_int dir=reg_hl;
+    int i;
+    for (i=0;i<tocopy;i++) {
+        nbhd_poke(page,dir,f->buf[f->pos+i]);
+        nbhd_advance(&page,&dir);
+    }
+    f->pos +=tocopy;
+
+    if (tocopy<count) {
+        reg_de=count-tocopy;
+        nbhd_return_error(25); //End of file
+    }
+    else nbhd_return_ok();
+}
+
+static void nbhd_dos_write(void)
+{
+    struct s_nbhd_file *f=nbhd_get_open_file();
+    if (f==NULL) return;
+
+    int count=(reg_de==0 ? 65536 : reg_de);
+
+    if (!nbhd_ensure_capacity(f,f->pos+count)) {
+        nbhd_return_error(26); //Disk full
+        return;
+    }
+
+    z80_byte page=reg_c;
+    z80_int dir=reg_hl;
+    int i;
+    for (i=0;i<count;i++) {
+        f->buf[f->pos+i]=nbhd_peek(page,dir);
+        nbhd_advance(&page,&dir);
+    }
+    f->pos +=count;
+    if (f->pos>f->size) f->size=f->pos;
+    f->dirty=1;
+
+    nbhd_return_ok();
+}
+
+static void nbhd_dos_byte_read(void)
+{
+    struct s_nbhd_file *f=nbhd_get_open_file();
+    if (f==NULL) return;
+
+    if (f->pos>=f->size) {
+        nbhd_return_error(25); //End of file
+        return;
+    }
+
+    reg_c=f->buf[f->pos++];
+    Z80_FLAGS=(Z80_FLAGS & (255-FLAG_Z)); //not soft-EOF
+    nbhd_return_ok();
+}
+
+static void nbhd_dos_byte_write(void)
+{
+    struct s_nbhd_file *f=nbhd_get_open_file();
+    if (f==NULL) return;
+
+    if (!nbhd_ensure_capacity(f,f->pos+1)) {
+        nbhd_return_error(26);
+        return;
+    }
+
+    f->buf[f->pos++]=reg_c;
+    if (f->pos>f->size) f->size=f->pos;
+    f->dirty=1;
+
+    nbhd_return_ok();
+}
+
+static void nbhd_dos_get_position(void)
+{
+    struct s_nbhd_file *f=nbhd_get_open_file();
+    if (f==NULL) return;
+
+    reg_de=(f->pos>>16)&0xFFFF;
+    reg_hl=f->pos&0xFFFF;
+    nbhd_return_ok();
+}
+
+static void nbhd_dos_set_position(void)
+{
+    struct s_nbhd_file *f=nbhd_get_open_file();
+    if (f==NULL) return;
+
+    int pos=(reg_de<<16)|reg_hl;
+    if (pos>f->size) pos=f->size;
+    f->pos=pos;
+    nbhd_return_ok();
+}
+
+static void nbhd_dos_get_eof(void)
+{
+    struct s_nbhd_file *f=nbhd_get_open_file();
+    if (f==NULL) return;
+
+    reg_de=(f->size>>16)&0xFFFF;
+    reg_hl=f->size&0xFFFF;
+    nbhd_return_ok();
+}
+
+static void nbhd_dos_delete(void)
+{
+    char name[NBHD_MAX_NAME];
+    char path[NBHD_MAX_PATH];
+
+    nbhd_read_filespec(reg_hl,name);
+    if (!nbhd_valid_name(name)) return;
+
+    if (!nbhd_find_host_file(name,path)) {
+        nbhd_return_error(23); //File not found
+        return;
+    }
+
+    debug_printf(VERBOSE_INFO,"NextBASIC host disk: delete %s",path);
+
+    if (remove(path)==0) nbhd_return_ok();
+    else nbhd_return_error(28); //File is read only
+}
+
+void traps_nextbasic_hostdisk(void)
+{
+
+    if (nbhd_dir==NULL) {
+        //One-time initialization: without ZESARUX_NEXTBASIC_DIR the handler
+        //switches itself off and never runs again
+        char *e=getenv("ZESARUX_NEXTBASIC_DIR");
+        if (e==NULL || e[0]==0) {
+            nextbasic_hostdisk_traps.v=0;
+            return;
+        }
+        nbhd_dir=strdup(e);
+        e=getenv("ZESARUX_NEXTBASIC_AUTOLOAD");
+        if (e!=NULL && e[0]!=0) nbhd_autoload=strdup(e);
+        debug_printf(VERBOSE_INFO,"NextBASIC host disk enabled on directory %s",nbhd_dir);
+    }
+
+    //+3DOS API jump table entries live at 0106h-0139h, every 3 bytes
+    if (reg_pc<0x0106 || reg_pc>0x0139) return;
+    if ((reg_pc-0x0106)%3) return;
+
+    //Only when the TBBlue runs in +3e mode (NextZXOS)...
+    if ((tbblue_registers[3]&7)!=3) return;
+
+    //...with normal paging and the DOS ROM (ROM 2) at 0000h-3FFFh
+    if (puerto_8189&1) return; //special RAM-in-ROM paging
+    if ((tbblue_registers[0x8c]&192)==128) return; //AltROM active on read
+
+    z80_byte rom_page=((puerto_8189>>1)&2) | ((puerto_32765>>4)&1);
+    if (rom_page!=2) return;
+
+    switch (reg_pc) {
+
+        case 0x0106: //DOS_OPEN
+            nbhd_dos_open();
+        break;
+
+        case 0x0109: //DOS_CLOSE
+            nbhd_dos_close();
+        break;
+
+        case 0x010C: //DOS_ABANDON
+            nbhd_dos_abandon();
+        break;
+
+        case 0x010F: //DOS_REF_HEAD
+            nbhd_dos_ref_head();
+        break;
+
+        case 0x0112: //DOS_READ
+            nbhd_dos_read();
+        break;
+
+        case 0x0115: //DOS_WRITE
+            nbhd_dos_write();
+        break;
+
+        case 0x0118: //DOS_BYTE_READ
+            nbhd_dos_byte_read();
+        break;
+
+        case 0x011B: //DOS_BYTE_WRITE
+            nbhd_dos_byte_write();
+        break;
+
+        case 0x0124: //DOS_DELETE
+            nbhd_dos_delete();
+        break;
+
+        case 0x0133: //DOS_GET_POSITION
+            nbhd_dos_get_position();
+        break;
+
+        case 0x0136: //DOS_SET_POSITION
+            nbhd_dos_set_position();
+        break;
+
+        case 0x0139: //DOS_GET_EOF
+            nbhd_dos_get_eof();
+        break;
+
+    }
+
+}
