   /* Check we're in the right ROM */
   if( !trap_check_rom( CHECK_TAPE_ROM ) ) return 3;
 
+  /* per-name autosave: a header block (flag 0x00 in A) begins a new SAVE,
+     so start a fresh tape to keep one program per output file */
+  if( autosave_dir && A == 0x00 ) {
+    libspectrum_tape_free( tape );
+    tape = libspectrum_tape_alloc();
+  }
+
   block = libspectrum_tape_block_alloc( LIBSPECTRUM_TAPE_BLOCK_ROM );
   
   /* The +2 here is for the flag and parity bytes */
@@ -611,6 +623,32 @@
   tape_modified = 1;
   ui_tape_browser_update( UI_TAPE_BROWSER_NEW_BLOCK, block );
 
+  /* per-name autosave: remember the name from the header block, then on the
+     following data block dump the completed one-program tape to disk. The
+     write goes to a temp file first and is renamed into place, so pulling
+     the power mid-write can never corrupt an existing saved program. */
+  if( autosave_dir ) {
+    if( data[0] == 0x00 ) {                  /* header block: capture name  */
+      int j; char *p = autosave_name;
+      for( j = 0; j < 10; j++ ) {
+        libspectrum_byte c = data[ 2 + j ];
+        if( c < 0x20 || c > 0x7e || c == '/' || c == '\\' ) c = '_';
+        *p++ = (char)c;
+      }
+      while( p > autosave_name && ( p[-1] == ' ' || p[-1] == '_' ) ) p--;
+      *p = '\0';
+      if( autosave_name[0] == '\0' ) strcpy( autosave_name, "untitled" );
+      autosave_have_name = 1;
+    } else if( autosave_have_name ) {        /* data block: pair complete   */
+      char path[ 4096 ], tmp[ 4096 ];
+      snprintf( path, sizeof( path ), "%s/%s.tzx", autosave_dir, autosave_name );
+      snprintf( tmp,  sizeof( tmp  ), "%s/.%s.tzx.tmp", autosave_dir,
+                autosave_name );
+      if( tape_write( tmp ) == 0 ) rename( tmp, path );
+      autosave_have_name = 0;
+    }
+  }
+
